{
  "@context": {
    "@version": 1.1,
    "bloom": "https://bloomcredit.io/vocab/",
    "schema": "https://schema.org/",
    "fibo": "https://spec.edmcouncil.org/fibo/ontology/",
    "id": "@id",
    "type": "@type",
    "Consumer": "bloom:Consumer",
    "CreditScore": "bloom:CreditScore",
    "CreditReport": "bloom:CreditReport",
    "TradeLine": "bloom:TradeLine",
    "MonitoringEnrollment": "bloom:MonitoringEnrollment",
    "consumer_id": "bloom:consumerId",
    "first_name": "schema:givenName",
    "last_name": "schema:familyName",
    "email": "schema:email",
    "phone": "schema:telephone",
    "date_of_birth": "schema:birthDate",
    "address": "schema:address",
    "street": "schema:streetAddress",
    "city": "schema:addressLocality",
    "state": "schema:addressRegion",
    "zip_code": "schema:postalCode",
    "status": "bloom:status",
    "created_at": "schema:dateCreated",
    "updated_at": "schema:dateModified",
    "bureau": "bloom:bureau",
    "score_type": "bloom:scoreType",
    "score": "bloom:score",
    "score_range_min": "bloom:scoreRangeMin",
    "score_range_max": "bloom:scoreRangeMax",
    "factors": "bloom:factors",
    "account_id": "bloom:accountId",
    "creditor_name": "bloom:creditorName",
    "account_type": "bloom:accountType",
    "account_status": "bloom:accountStatus",
    "credit_limit": "bloom:creditLimit",
    "current_balance": "bloom:currentBalance",
    "payment_status": "bloom:paymentStatus",
    "opened_date": "bloom:openedDate",
    "last_activity_date": "bloom:lastActivityDate",
    "enrollment_id": "bloom:enrollmentId",
    "bureaus": "bloom:bureaus",
    "alert_types": "bloom:alertTypes",
    "webhook_url": "bloom:webhookUrl",
    "trade_lines": "bloom:tradeLines",
    "trade_lines_count": "bloom:tradeLinesCount",
    "open_accounts": "bloom:openAccounts",
    "total_balance": "bloom:totalBalance",
    "pull_date": "bloom:pullDate",
    "ssn": "bloom:ssn",
    "reports": "bloom:reports",
    "scores": "bloom:scores"
